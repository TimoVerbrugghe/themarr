# Plex Configuration
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here

# Media Library Paths (host paths to be mounted in container)
# Mount these at the SAME path as your Plex container so Themarr can
# resolve theme files using the exact paths Plex reports.
TV_SHOWS_HOST_PATH=/mnt/tv
MOVIES_HOST_PATH=/mnt/movies

# Web UI
FLASK_DEBUG=false
DEFAULT_THEME=dark
DEFAULT_VIEW=list

# Pushover notifications (optional — leave blank to disable)
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
