# Plex Configuration
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here

# Media Library Paths (host paths to be mounted in container)
TV_SHOWS_HOST_PATH=/mnt/tv
MOVIES_HOST_PATH=/mnt/movies

# Container paths (TV_SHOWS_PATH kept for CLI compatibility; TV_PATH is a web-app alias)
TV_SHOWS_PATH=/tv
TV_PATH=/tv
MOVIES_PATH=/movies

# Web UI
WEB_PORT=8080
FLASK_DEBUG=false

# Logging
VERBOSE=false
VERBOSE_MATCHING=false

# Features
OVERWRITE=false

# Pushover notifications (optional — leave blank to disable)
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Webhook authentication (optional — leave blank to allow all)
WEBHOOK_USERNAME=
WEBHOOK_PASSWORD=

# Plex retry settings for webhooks (how long to wait for Plex to pick up new media)
PLEX_RETRY_ATTEMPTS=10
PLEX_RETRY_DELAY=30
