# Plex Configuration (optional when using Jellyfin-only setup)
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here

# Jellyfin Configuration (optional)
JELLYFIN_URL=
JELLYFIN_API_KEY=
# Optional: force a specific Jellyfin user id; defaults to first user if unset
JELLYFIN_USER_ID=

# Web UI
FLASK_DEBUG=false
DEFAULT_THEME=dark
DEFAULT_VIEW=list

# Flask session secret key — set to a stable random value so sessions survive restarts.
# If unset, a new random key is generated each time the app starts (all sessions invalidated on restart).
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# UI Authentication
# Set AUTH_USERNAME and AUTH_PASSWORD to enable the login screen with
# username/password credentials.  When DISABLE_AUTH=false, both values
# must be set or the Web UI will stay on a warning page.
AUTH_USERNAME=
AUTH_PASSWORD=
# Set DISABLE_AUTH=true to bypass all UI authentication entirely.
# Only use this when a trusted reverse proxy (e.g. Authelia, Authentik)
# already handles authentication in front of Themarr.
DISABLE_AUTH=false

# API key for mutating API routes (POST/DELETE/etc.)
# Used for programmatic / Sonarr/Radarr webhook access regardless of the
# UI auth mode above.
# If left blank, Themarr auto-generates one at startup and shows it in Settings.
API_KEY=

# Optional Plex webhook Basic Auth protection
WEBHOOK_USERNAME=
WEBHOOK_PASSWORD=

# Pushover notifications (optional — leave blank to disable)
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
