# Plex Configuration
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here

# Jellyfin Configuration (optional)
JELLYFIN_URL=
JELLYFIN_API_KEY=
# Optional: force a specific Jellyfin user id; defaults to first user if unset
JELLYFIN_USER_ID=

# Media Library Paths (host paths to be mounted in container)
# Mount these at the SAME path as your Plex container so Themarr can
# resolve theme files using the exact paths Plex reports.
TV_SHOWS_HOST_PATH=/mnt/tv
MOVIES_HOST_PATH=/mnt/movies

# Web UI
FLASK_DEBUG=false
DEFAULT_THEME=dark
DEFAULT_VIEW=list

# UI Authentication
# Set AUTH_USERNAME and AUTH_PASSWORD to enable the login screen with
# username/password credentials.  Leave both blank to fall back to
# API token authentication (API_AUTH_TOKEN below).
AUTH_USERNAME=
AUTH_PASSWORD=
# Set DISABLE_AUTH=true to bypass all UI authentication entirely.
# Only use this when a trusted reverse proxy (e.g. Authelia, Authentik)
# already handles authentication in front of Themarr.
DISABLE_AUTH=false

# API auth token for mutating API routes (POST/DELETE/etc.)
# Used for programmatic / Sonarr/Radarr webhook access regardless of the
# UI auth mode above.
# If left blank, Themarr auto-generates one at startup and shows it in Settings.
API_AUTH_TOKEN=

# Flask session secret key — used to sign the browser session cookie.
# Set this to a stable random value to keep sessions alive across container restarts.
# If left blank, a new key is generated on every startup (sessions reset on restart).
FLASK_SECRET_KEY=

# Optional Plex webhook Basic Auth protection
WEBHOOK_USERNAME=
WEBHOOK_PASSWORD=

# Pushover notifications (optional — leave blank to disable)
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
